<% content_for(:page_title, "Expedientes") %>

<div class="page-header">
  <div>
    <h1 class="page-title">Expedientes</h1>
    <p class="page-subtitle"><%= @expedientes.size %> expedientes</p>
  </div>
  <%= link_to new_expediente_path, class: "btn btn-primary" do %>
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
    Nuevo expediente
  <% end %>
</div>

<%# Búsqueda y filtros %>
<div class="card mb-6">
  <div class="card-body">
    <%= search_form_for @q, url: expedientes_path, html: { class: "flex items-center gap-4", data: { turbo_frame: "_top" } } do |f| %>
      <div class="flex-1 flex items-center bg-white rounded-lg shadow-sm border border-gray-300 px-3 overflow-hidden focus-within:ring-1 focus-within:ring-primary-500 focus-within:border-primary-500 transition-colors">
        <svg class="h-5 w-5 text-gray-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
        <%= f.search_field :caratula_or_numero_causa_cont, class: "w-full border-transparent focus:border-transparent focus:ring-0 text-sm py-2 px-2 bg-transparent outline-none", placeholder: "Buscar por carátula o número de causa..." %>
      </div>
      <div class="w-48 shrink-0">
        <%= f.select :status_eq, options_for_select([["Todos los estados", ""], ["Activo", "activo"], ["En trámite", "en_tramite"], ["Paralizado", "paralizado"], ["Archivado", "archivado"], ["Finalizado", "finalizado"]], params.dig(:q, :status_eq)), {}, class: "form-select w-full" %>
      </div>
      <%= f.submit "Buscar", class: "btn btn-secondary" %>
      <%= link_to "Limpiar", expedientes_path, class: "btn btn-secondary" %>
    <% end %>
  </div>
</div>

<%# Tabla %>
<div class="card">
  <div class="table-container">
    <% if @expedientes.any? %>
      <table class="data-table">
        <thead>
          <tr>
            <th>Carátula</th>
            <th>Nº Causa</th>
            <th>Estado</th>
            <th>Cliente</th>
            <th>Fuero</th>
            <th>Abogado</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% @expedientes.each do |exp| %>
            <tr>
              <td>
                <%= link_to exp, class: "font-medium text-primary-600 hover:text-primary-700" do %>
                  <%= exp.caratula.truncate(45) %>
                <% end %>
              </td>
              <td class="text-gray-500 text-sm"><%= exp.numero_causa || "—" %></td>
              <td><%= status_badge(exp.status) %></td>
              <td><%= link_to exp.client.full_name, exp.client, class: "text-sm text-gray-700 hover:text-primary-600" %></td>
              <td class="text-gray-500 text-sm"><%= exp.fuero&.capitalize %></td>
              <td class="text-gray-500 text-sm"><%= exp.assigned_to&.full_name || "—" %></td>
              <td class="text-right">
                <%= link_to "Ver", exp, class: "text-sm text-primary-600 hover:text-primary-700" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <div class="empty-state">
        <svg class="empty-state-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
        <p class="empty-state-title">Sin expedientes</p>
        <p class="empty-state-text"><%= link_to "Crear el primero →", new_expediente_path, class: "text-primary-600" %></p>
      </div>
    <% end %>
  </div>
  <% if @pagy && @pagy.pages > 1 %>
    <div class="px-6 py-3 border-t border-gray-100">
      <%== pagy_nav(@pagy) %>
    </div>
  <% end %>
</div>
