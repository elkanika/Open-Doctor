<div class="simple-calendar bg-white rounded-lg border border-gray-200 shadow-sm overflow-hidden">
  <div class="calendar-heading flex items-center justify-between px-6 py-4 border-b border-gray-200 bg-gray-50">
    <div class="flex items-center gap-4">
      <h2 class="text-lg font-semibold text-gray-900 capitalize">
        <time datetime="<%= start_date.strftime('%Y-%m') %>">
          <%= t('date.month_names')[start_date.month] %> <%= start_date.year %>
        </time>
      </h2>
    </div>

    <nav class="flex items-center gap-2">
      <%= link_to calendar.url_for_previous_view, class: "p-2 text-gray-500 hover:text-gray-700 hover:bg-gray-100 rounded-md transition-colors" do %>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
      <% end %>
      
      <%= link_to t('simple_calendar.today', default: 'Hoy'), calendar.url_for_today_view, class: "px-3 py-1.5 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-md hover:bg-gray-50 transition-colors shadow-sm" %>
      
      <%= link_to calendar.url_for_next_view, class: "p-2 text-gray-500 hover:text-gray-700 hover:bg-gray-100 rounded-md transition-colors" do %>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      <% end %>
    </nav>
  </div>

  <table class="w-full border-collapse table-fixed">
    <thead class="bg-gray-50 border-b border-gray-200">
      <tr>
        <% date_range.slice(0, 7).each do |day| %>
          <th class="py-3 px-2 text-center text-xs font-semibold tracking-wider text-gray-500 uppercase">
            <%= t('date.abbr_day_names')[day.wday] %>
          </th>
        <% end %>
      </tr>
    </thead>

    <tbody class="divide-y divide-gray-200 bg-white text-gray-600">
      <% date_range.each_slice(7) do |week| %>
        <tr class="divide-x divide-gray-200 h-32">
          <% week.each do |day| %>
            <%= content_tag :td, class: "#{calendar.td_classes_for(day).join(' ')} p-0 align-top #{day.month != start_date.month ? 'bg-gray-50' : ''}" do %>
              <% instance_exec(day, calendar.sorted_events_for(day), &passed_block) %>
            <% end %>
          <% end %>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
