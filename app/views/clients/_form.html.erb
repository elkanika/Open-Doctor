<%= form_with(model: client, class: "space-y-6") do |f| %>
  <% if client.errors.any? %>
    <div class="flash flash-alert">
      <svg class="w-5 h-5 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/></svg>
      <div>
        <p class="font-medium">Se encontraron <%= pluralize(client.errors.count, "error") %>:</p>
        <ul class="list-disc list-inside mt-1 text-sm">
          <% client.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    </div>
  <% end %>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    <div class="form-group">
      <%= f.label :first_name, "Nombre", class: "form-label" %>
      <%= f.text_field :first_name, class: "form-input", required: true %>
    </div>

    <div class="form-group">
      <%= f.label :last_name, "Apellido", class: "form-label" %>
      <%= f.text_field :last_name, class: "form-input", required: true %>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    <div class="form-group">
      <%= f.label :document_type, "Tipo de documento", class: "form-label" %>
      <%= f.select :document_type, ["DNI", "CUIT", "CUIL", "Pasaporte"], {}, class: "form-select" %>
    </div>

    <div class="form-group">
      <%= f.label :document_number, "Número de documento", class: "form-label" %>
      <%= f.text_field :document_number, class: "form-input" %>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    <div class="form-group">
      <%= f.label :email, "Email", class: "form-label" %>
      <%= f.email_field :email, class: "form-input" %>
    </div>

    <div class="form-group">
      <%= f.label :phone, "Teléfono", class: "form-label" %>
      <%= f.text_field :phone, class: "form-input" %>
    </div>
  </div>

  <div class="form-group">
    <%= f.label :address, "Domicilio", class: "form-label" %>
    <%= f.text_area :address, class: "form-textarea", rows: 2 %>
  </div>

  <div class="form-group">
    <%= f.label :notes, "Notas", class: "form-label" %>
    <%= f.text_area :notes, class: "form-textarea", rows: 3, placeholder: "Notas internas sobre el cliente..." %>
  </div>

  <div class="form-group">
    <%= f.label :documents, "Documentos adjuntos", class: "form-label" %>
    <%= f.file_field :documents, multiple: true, class: "form-input" %>
  </div>

  <div class="flex items-center gap-3 pt-4 border-t border-gray-200">
    <%= f.submit client.persisted? ? "Actualizar cliente" : "Crear cliente", class: "btn btn-primary" %>
    <%= link_to "Cancelar", client.persisted? ? client_path(client) : clients_path, class: "btn btn-secondary" %>
  </div>
<% end %>
