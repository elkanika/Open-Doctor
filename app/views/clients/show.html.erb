<% content_for(:page_title, @client.full_name) %>

<div class="page-header">
  <div>
    <h1 class="page-title"><%= @client.full_name %></h1>
    <p class="page-subtitle"><%= "#{@client.document_type} #{@client.document_number}" if @client.document_number.present? %></p>
  </div>
  <div class="flex items-center gap-2">
    <%= link_to "Editar", edit_client_path(@client), class: "btn btn-secondary" %>
    <%= button_to "Eliminar", client_path(@client), method: :delete, class: "btn btn-danger", data: { turbo_confirm: "¿Estás seguro de eliminar este cliente?" } %>
  </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
  <%# Sidebar: Info del cliente y Documentos %>
  <div class="space-y-6">
    <div class="card">
      <div class="card-header">
        <h2 class="font-semibold">Datos del cliente</h2>
      </div>
      <div class="card-body space-y-3">
        <% if @client.email.present? %>
          <div>
            <p class="text-xs text-gray-500">Email</p>
            <p class="text-sm"><%= @client.email %></p>
          </div>
        <% end %>
        <% if @client.phone.present? %>
          <div>
            <p class="text-xs text-gray-500">Teléfono</p>
            <p class="text-sm"><%= @client.phone %></p>
          </div>
        <% end %>
        <% if @client.address.present? %>
          <div>
            <p class="text-xs text-gray-500">Domicilio</p>
            <p class="text-sm"><%= @client.address %></p>
          </div>
        <% end %>
        <% if @client.notes.present? %>
          <div>
            <p class="text-xs text-gray-500">Notas</p>
            <p class="text-sm text-gray-600"><%= @client.notes %></p>
          </div>
        <% end %>
      </div>
    </div>

    <% if @client.documents.attached? %>
      <div class="card">
        <div class="card-header">
          <h2 class="font-semibold">Documentos (<%= @client.documents.count %>)</h2>
        </div>
        <div class="card-body p-0 divide-y divide-gray-100">
          <% @client.documents.each do |doc| %>
            <div class="p-4 flex items-center justify-between hover:bg-gray-50 transition-colors">
              <div class="flex items-center gap-3">
                <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.172 7l-6.586 6.586a2 2 0 102.828 2.828l6.414-6.586a4 4 0 00-5.656-5.656l-6.415 6.585a6 6 0 108.486 8.486L20.5 13"/></svg>
                <div>
                  <p class="text-sm font-medium text-gray-900"><%= doc.filename %></p>
                  <p class="text-xs text-gray-500"><%= number_to_human_size(doc.byte_size) %></p>
                </div>
              </div>
              <%= link_to "Descargar", rails_blob_path(doc, disposition: "attachment"), class: "text-primary-600 hover:text-primary-800 text-sm font-medium" %>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>

  <%# Expedientes del cliente %>
  <div class="lg:col-span-2 card">
    <div class="card-header">
      <h2 class="font-semibold">Expedientes (<%= @expedientes.size %>)</h2>
      <%= link_to new_expediente_path(expediente: { client_id: @client.id }), class: "btn btn-primary btn-sm" do %>
        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
        Nuevo
      <% end %>
    </div>
    <div class="card-body p-0">
      <% if @expedientes.any? %>
        <table class="data-table">
          <thead>
            <tr>
              <th>Carátula</th>
              <th>Estado</th>
              <th>Fuero</th>
              <th>Abogado</th>
            </tr>
          </thead>
          <tbody>
            <% @expedientes.each do |exp| %>
              <tr>
                <td>
                  <%= link_to exp, class: "text-primary-600 hover:text-primary-700 font-medium" do %>
                    <%= exp.caratula.truncate(50) %>
                  <% end %>
                </td>
                <td><%= status_badge(exp.status) %></td>
                <td class="text-gray-500"><%= exp.fuero&.capitalize %></td>
                <td class="text-gray-500"><%= exp.assigned_to&.full_name || "—" %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      <% else %>
        <div class="empty-state">
          <p class="empty-state-title">Sin expedientes</p>
          <p class="empty-state-text">Este cliente no tiene expedientes aún.</p>
        </div>
      <% end %>
    </div>
  </div>
</div>
