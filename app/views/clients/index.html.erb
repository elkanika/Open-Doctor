<% content_for(:page_title, "Clientes") %>

<div class="page-header">
  <div>
    <h1 class="page-title">Clientes</h1>
    <p class="page-subtitle"><%= @clients.size %> clientes en el estudio</p>
  </div>
  <%= link_to new_client_path, class: "btn btn-primary" do %>
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
    Nuevo cliente
  <% end %>
</div>

<%# Búsqueda %>
<div class="card mb-6">
  <div class="card-body">
    <%= search_form_for @q, url: clients_path, html: { class: "flex items-center gap-4", data: { turbo_frame: "_top" } } do |f| %>
      <div class="flex-1 flex items-center bg-white rounded-lg shadow-sm border border-gray-300 px-3 overflow-hidden focus-within:ring-1 focus-within:ring-primary-500 focus-within:border-primary-500 transition-colors">
        <svg class="h-5 w-5 text-gray-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
        <%= f.search_field :last_name_or_first_name_or_document_number_cont, class: "w-full border-transparent focus:border-transparent focus:ring-0 text-sm py-2 px-2 bg-transparent outline-none", placeholder: "Buscar por nombre o documento..." %>
      </div>
      <%= f.submit "Buscar", class: "btn btn-secondary" %>
      <%= link_to "Limpiar", clients_path, class: "btn btn-secondary" %>
    <% end %>
  </div>
</div>

<%# Tabla de clientes %>
<div class="card">
  <div class="table-container">
    <% if @clients.any? %>
      <table class="data-table">
        <thead>
          <tr>
            <th>Nombre</th>
            <th>Documento</th>
            <th>Email</th>
            <th>Teléfono</th>
            <th>Expedientes</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% @clients.each do |client| %>
            <tr>
              <td>
                <%= link_to client, class: "font-medium text-primary-600 hover:text-primary-700" do %>
                  <%= client.full_name %>
                <% end %>
              </td>
              <td><%= "#{client.document_type} #{client.document_number}" if client.document_number.present? %></td>
              <td class="text-gray-500"><%= client.email %></td>
              <td class="text-gray-500"><%= client.phone %></td>
              <td><span class="badge badge-gray"><%= client.expedientes.size %></span></td>
              <td class="text-right">
                <%= link_to "Editar", edit_client_path(client), class: "text-sm text-primary-600 hover:text-primary-700" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <div class="empty-state">
        <svg class="empty-state-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
        <p class="empty-state-title">Sin clientes</p>
        <p class="empty-state-text"><%= link_to "Agregar el primero →", new_client_path, class: "text-primary-600" %></p>
      </div>
    <% end %>
  </div>
  <% if @pagy && @pagy.pages > 1 %>
    <div class="px-6 py-3 border-t border-gray-100">
      <%== pagy_nav(@pagy) %>
    </div>
  <% end %>
</div>
